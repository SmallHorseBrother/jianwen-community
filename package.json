{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:agent": "node scripts/ui-test-agent.mjs",
    "wechat:intake:dry": "node scripts/wechat-feedback-intake.mjs --config scripts/wechat-feedback-sources.example.json --dry-run",
    "wechat:intake": "node scripts/wechat-feedback-intake.mjs --config scripts/wechat-feedback-sources.example.json --write",
    "wechat:bridge:dry": "node scripts/wechat-message-bridge.mjs --config scripts/wechat-feedback-sources.example.json --dry-run",
    "wechat:bridge": "node scripts/wechat-message-bridge.mjs --config scripts/wechat-feedback-sources.example.json",
    "wechat:bridge:watch": "node scripts/wechat-message-bridge.mjs --config scripts/wechat-feedback-sources.example.json --watch --interval 120",
    "task-runner": "node scripts/task-runner.mjs",
    "task-runner:once": "node scripts/task-runner.mjs --once",
    "task-runner:dry": "node scripts/task-runner.mjs --once --dry-run",
    "import:question-planet": "node scripts/import-question-planet.mjs",
    "import:question-planet:dry": "node scripts/import-question-planet.mjs --dry-run",
    "questions:embed": "node scripts/generate-question-embeddings.mjs",
    "questions:embed:dry": "node scripts/generate-question-embeddings.mjs --dry-run",
    "questions:edges": "node scripts/build-question-edges.mjs",
    "questions:edges:dry": "node scripts/build-question-edges.mjs --dry-run",
    "questions:refresh": "node scripts/refresh-question-semantics.mjs",
    "questions:refresh:dry": "node scripts/refresh-question-semantics.mjs --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/three": "^0.184.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "fast-check": "^4.4.0",
    "globals": "^15.9.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^4.0.16"
  }
}
